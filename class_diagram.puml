@startuml ClassDiagram_TaskManager_Partie1

skinparam classAttributeIconSize 0
skinparam classFontStyle bold
skinparam classBackgroundColor #FAFAFA
skinparam classBorderColor #666666
skinparam arrowColor #444444
skinparam arrowThickness 1.2
skinparam linetype ortho

' ===================== ENUMERATIONS =====================

enum TaskStatus <<enumeration>> #C0DD97 {
    PENDING
    IN_PROGRESS
    COMPLETED
    ABANDONED
}

enum Priority <<enumeration>> #C0DD97 {
    LOW
    MEDIUM
    HIGH
}

' ===================== INTERFACE Task =====================

interface Task <<interface>> #CECBF6 {
    + editName(name : String) : void
    + editDescription(desc : String) : void
    + editDueDate(date : Date) : void
    + markCompleted() : void
    + markInProgress() : void
    + markAbandoned() : void
    + markPending() : void
    + getStatus() : TaskStatus
    + setPriority(p : Priority) : void
    + getPriority() : Priority
    + addComment(content : String) : void
    + getComments() : void
    + getId() : UUID
    + getName() : String
    + getDescription() : String
    + getDueDate() : Date
}

' ===================== CLASSE CONCRETE TaskImpl =====================

class TaskImpl #B5D4F4 {
    - id : UUID
    - name : String
    - description : String
    - dueDate : Date
    - status : TaskStatus
    - priority : Priority
    --
    + TaskImpl(name : String, description : String, dueDate : Date)
    + editName(name : String) : void
    + editDescription(desc : String) : void
    + editDueDate(date : Date) : void
    + markCompleted() : void
    + markInProgress() : void
    + markAbandoned() : void
    + markPending() : void
    + getStatus() : TaskStatus
    + setPriority(p : Priority) : void
    + getPriority() : Priority
    + addComment(content : String) : void
    + getComments() : void
    + getId() : UUID
    + getName() : String
    + getDescription() : String
    + getDueDate() : Date
}

' ===================== CLASSE Comment =====================

class Comment #FAC775 {
    - id : UUID
    - content : String
    - createdAt : Date
    --
    + Comment(content : String)
    + getContent() : String
    + getCreatedAt() : Date
    + getId() : UUID
}

' ===================== CLASSE InputValidator =====================

class InputValidator #FAC775 {
    - {static} MAX_NAME_LEN : int = 100
    - {static} MAX_DESC_LEN : int = 500
    --
    + validateName(name : String) : String
    + validateDescription(desc : String) : String
    + validateDueDate(date : Date) : Date
}

' ===================== CLASSE ABSTRAITE TaskList =====================

abstract class TaskList #F4C0D1 {
    --
    + {abstract} add(t : Task) : void
    + {abstract} remove(id : UUID) : void
    + {abstract} update(t : Task) : void
    + {abstract} display() : void
    + {abstract} getAll() : void
    + {abstract} findById(id : UUID) : Task
    + {abstract} search(keyword : String) : void
}

' ===================== CLASSE CONCRETE TaskListImpl =====================

class TaskListImpl #F7C1C1 {
    - validator : InputValidator
    --
    + TaskListImpl()
    + add(t : Task) : void
    + remove(id : UUID) : void
    + update(t : Task) : void
    + display() : void
    + getAll() : void
    + findById(id : UUID) : Task
    + search(keyword : String) : void
    + filterByStatus(status : TaskStatus) : void
    + filterByPriority(priority : Priority) : void
    + sortByDueDate() : void
    + sortByPriority() : void
    + exportToJSON(filePath : String) : void
    + exportToXML(filePath : String) : void
    + importFromJSON(filePath : String) : void
    + importFromXML(filePath : String) : void
}

' ===================== CLASSE TaskManagerGUI (View) =====================

class TaskManagerGUI #9FE1CB {
    - mainFrame : JFrame
    - taskTable : JTable
    --
    + TaskManagerGUI(taskList : TaskListImpl)
    + refreshView() : void
    + showCreateDialog() : void
    + showEditDialog(t : Task) : void
    + showDeleteConfirm(id : UUID) : void
    + applyFilter(status : TaskStatus) : void
    + applySort(criterion : String) : void
    + showSearchResults(keyword : String) : void
}

' ===================== RELATIONS =====================

' TaskImpl implémente Task
Task <|.. TaskImpl

' TaskListImpl hérite de TaskList
TaskList <|-- TaskListImpl

' TaskImpl utilise TaskStatus et Priority (dépendances)
TaskImpl ..> TaskStatus : uses
TaskImpl ..> Priority  : uses

' TaskImpl contient des Comment (composition)
TaskImpl "1" *-- "0..*" Comment : contains >

' TaskList agrège des Task (agrégation — remplace tasks: List<Task>)
TaskList "1" o-- "0..*" Task : manages >

' TaskListImpl agrège des Task (remplace tasks: ArrayList<Task>)
TaskListImpl "1" o-- "0..*" Task : manages >

' TaskListImpl utilise InputValidator (dépendance)
TaskListImpl ..> InputValidator : uses >

' TaskManagerGUI délègue à TaskListImpl (dépendance)
TaskManagerGUI ..> TaskListImpl : delegates >

@enduml
