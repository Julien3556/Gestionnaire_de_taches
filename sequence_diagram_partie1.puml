@startuml DiagrammeSequence_Partie1
title Diagramme de Séquence — Partie 1 : Création et Ajout d'une Tâche

skinparam sequenceMessageAlign center
skinparam responseMessageBelowArrow true

actor "Utilisateur" as User

participant "TaskManagerGUI\n(View)" as GUI
participant "TaskListImpl\n(Controller / Model)" as TLI
participant "TaskValidator\n(Validation)" as VAL
participant "TaskImpl\n(Model)" as TASK

== 1. Saisie des données par l'utilisateur ==

User -> GUI : Ouvre le formulaire de création
activate GUI

GUI --> User : Affiche le formulaire\n(name, description, dueDate, priority, status)

User -> GUI : Remplit et soumet le formulaire\n(name, description, dueDate, priority)
note right of User
  Exemple de champs saisis :
  • name       : "Préparer rapport"
  • description: "Rapport Microprocessoeurs"
  • dueDate    : 01/04/2026
  • priority   : HIGH
  • status     : PENDING (défaut)
end note

== 2. Validation des entrées (avant création) ==

GUI -> TLI : addTask(name, description, dueDate, priority)
activate TLI

TLI -> VAL : validate(name, description, dueDate, priority)
activate VAL

alt Champ name vide ou null
    VAL --> TLI : ValidationException("Le nom ne peut pas être vide")
    TLI --> GUI : Erreur de validation
    GUI --> User : Affiche message d'erreur\n"Le nom ne peut pas être vide"
else date invalide
    VAL --> TLI : ValidationException("Date d'échéance invalide")
    TLI --> GUI : Erreur de validation
    GUI --> User : Affiche message d'erreur\n"Format de date invalide (attendu : dd/MM/yyyy)."
else Toutes les entrées sont valides
    VAL --> TLI : true (validation OK)
    deactivate VAL
    note over TLI : Les entrées sont valides,\non procède à la création
end

== 3. Création de l'objet TaskImpl ==

TLI -> TASK : new TaskImpl(name, description, dueDate)
activate TASK

TASK -> TASK : setPriority(LOW)
TASK -> TASK : setStatus(PENDING)
note right of TASK
  Priority par défaut = LOW
  Status par défaut = PENDING
end note

TASK --> TLI : taskImpl (objet créé)
deactivate TASK

== 4. Ajout de la tâche à la liste ==

TLI -> TLI : taskList.add(taskImpl)


TLI --> GUI : Succès — tâche créée et ajoutée
deactivate TLI

== 5. Mise à jour de l'interface graphique ==

GUI -> TLI : displayTasks()
activate TLI
TLI --> GUI : Liste mise à jour [Task, ...]
deactivate TLI

GUI --> User : Affiche la liste des tâches\n(avec la nouvelle tâche visible)
deactivate GUI

@enduml
